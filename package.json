    "dotenv": "^16.3.1",
    "pg": "^8.11.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.1.2",
    "bcryptjs": "^2.4.3",
    "uuid": "^9.0.0",
    "clsx": "^2.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "concurrently": "^8.2.2",
