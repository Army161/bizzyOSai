# ===== APPLICATION =====
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NODE_ENV=development
VERCEL_ENV=development
APP_NAME=bizzyOSai
APP_VERSION=1.0.0

# ===== DATABASE =====
DATABASE_URL=postgresql://bizzyai_user:bizzyai_password@localhost:5432/bizzyai
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bizzyai
DB_USER=bizzyai_user
DB_PASSWORD=your_secure_password
DB_POOL_MIN=2
DB_POOL_MAX=10

# ===== AUTHENTICATION & SECURITY =====
JWT_SECRET=your_super_secure_jwt_secret_minimum_32_characters_long
JWT_EXPIRATION=7d
ENCRYPTION_KEY=your_encryption_key_32_characters
SESSION_SECRET=your_session_secret
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# ===== PAYMENT - STRIPE =====
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
STRIPE_PRODUCT_ID=prod_placeholder

# ===== COMMUNICATION - TWILIO =====
TWILIO_ACCOUNT_SID=placeholder_sid
TWILIO_AUTH_TOKEN=placeholder_token
TWILIO_PHONE_NUMBER=+1234567890

# ===== AI & INTELLIGENCE =====
CLAUDE_API_KEY=placeholder_key
GOOGLE_GEMINI_API_KEY=placeholder_key
PERPLEXITY_API_KEY=placeholder_key
JULIUS_AI_API_KEY=placeholder_key

# ===== GOOGLE SERVICES =====
GOOGLE_MAPS_API_KEY=placeholder_key
GOOGLE_BUSINESS_API_KEY=placeholder_key
GOOGLE_ANALYTICS_API_KEY=placeholder_key
GOOGLE_TRENDS_API_KEY=placeholder_key
GOOGLE_CLOUD_PROJECT_ID=placeholder_id
GOOGLE_CLOUD_KEY_PATH=./keys/google-cloud-key.json
GOOGLE_SHEETS_API_KEY=placeholder_key

# ===== DEVELOPMENT & DEPLOYMENT =====
GITHUB_TOKEN=placeholder_token
GITHUB_APP_ID=placeholder_id
VERCEL_API_TOKEN=placeholder_token
VERCEL_ORG_ID=placeholder_id
VERCEL_PROJECT_ID=placeholder_id
REPLIT_API_KEY=placeholder_key

# ===== ADVANCED AI PLATFORMS =====
LOVABLE_API_KEY=placeholder_key
EMERGENT_API_KEY=placeholder_key
ANTIGRAVITY_API_KEY=placeholder_key
OPENCLAW_API_KEY=placeholder_key

# ===== LOGGING & MONITORING =====
LOG_LEVEL=info
SENTRY_DSN=placeholder_dsn
ENABLE_DEBUG=false

# ===== EMAIL =====
SENDGRID_API_KEY=placeholder_key
EMAIL_FROM=noreply@bizzyosai.com

# ===== ANALYTICS =====
GOOGLE_ANALYTICS_ID=UA-xxxxxxxxx-x
MIXPANEL_TOKEN=placeholder_token

# ===== FEATURE FLAGS =====
ENABLE_BETA_FEATURES=true
ENABLE_CUSTOM_BRANDING=true
ENABLE_WHITE_LABEL=false
